Private Sub Workbook_Open()
    On Error GoTo EH
    StartApp
    Exit Sub
EH:
    Application.Visible = True
    LogErr "ThisWorkbook.Workbook_Open"

    MsgBox "Greška pri pokretanju aplikacije. Pogledajte log.", vbCritical
End Sub


Private Sub Workbook_BeforeClose(Cancel As Boolean)
    On Error GoTo EH

    modMain.ShutdownApp

    Exit Sub

EH:
    LogErr "ThisWorkbook.Workbook_BeforeClose"
End Sub
